use module math: "./foreign_rust_math"

let worker = automatic {
    let area = math.circle_area(5.0)
    print("Circle area (r=5): " + to_string(area))

    let rect = math.rectangle_area(4.0, 6.0)
    print("Rectangle area (4x6): " + to_string(rect))

    let hyp = math.hypotenuse(3.0, 4.0)
    print("Hypotenuse (3,4): " + to_string(hyp))

    stop_orch()
}

orchestrator main(procs: process[worker]) { }
